# ─────────────────────────────────────────────────────────────────
#  NYC Traffic Pipeline — Environment Variables
#  Copy this file to .env and fill in values before running.
#
#  cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# ── NYC Open Data (optional but recommended) ──────────────────────
# Register free at https://data.cityofnewyork.us/profile/app_tokens
# Without a token you get ~1000 req/hour per IP.
# With a token the limit is much higher (effectively unlimited for this project).
NYC_OPENDATA_APP_TOKEN=

# ── Kafka (auto-configured by docker-compose — do not change) ─────
# These are set automatically in docker-compose.yml via x-kafka-env.
# Only change these if you are running WITHOUT docker compose.
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
TOPIC_TRAFFIC_RAW=traffic-raw
TOPIC_TRAFFIC_VALIDATED=traffic-validated
TOPIC_TRAFFIC_DLQ=traffic-dlq

# ── Producer tuning ───────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60
BATCH_LIMIT=1000

# ── Confluent Cloud (alternative to local Kafka) ──────────────────
# Uncomment these and remove the local Kafka services from
# docker-compose.yml if using Confluent Cloud instead.
# KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
# KAFKA_SASL_USERNAME=<api-key>
# KAFKA_SASL_PASSWORD=<api-secret>
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=PLAIN

# ─────────────────────────────────────────────────────────────────────────────
#  NYC Traffic Pipeline — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets & credentials ─────────────────────────────────────────────────────
.env
*.pem
*.key
*.crt

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
producer_stats.json

# ── Spark ─────────────────────────────────────────────────────────────────────
checkpoints/
derby.log
metastore_db/
spark-warehouse/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Docker volumes (if mounted locally) ──────────────────────────────────────
volumes/

# ── MongoDB local data ────────────────────────────────────────────────────────
data/db/

# ── Trained ML models (large binaries) ───────────────────────────────────────
models/*.joblib
models/*.pkl
